import java.util.*;

class Main {
    public static String intToBinaryString(int n) {
        String result = "";
        while (n > 0) {
            result = (n % 2) + result;
            n = n / 2;
        }
        return result;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter a number: ");
        int n = sc.nextInt();

        System.out.println(n + " in binary is " + intToBinaryString(n));
    }
}
